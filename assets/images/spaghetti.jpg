564x/a4/fe/65/a4fe657820146eb46e9c96a51cffb832.jpg"},"736x":{"width":736,"height":981,"url":"https://i1-e.pinimg.com/736x/a4/fe/65/a4fe657820146eb46e9c96a51cffb832.jpg"},"orig":{"width":1363,"height":1817,"url":"https://i.pinimg.com/originals/a4/fe/65/a4fe657820146eb46e9c96a51cffb832.jpg"}},"access":[],"is_eligible_for_pre_loved_goods_label":false,"link_domain":{"id":"www.instagram.com"},"dominant_color":"#393a38","pinner":{"node_id":"VXNlcjozMTQ3NTk1OTg4NjUxNDA4MTU=","image_medium_url":"https://i1-e.pinimg.com/75x75_RS/7d/cc/80/7dcc801c68d277fb598541c585a6740f.jpg","username":"adudaeva","id":"314759598865140815","is_primary_website_verified":false,"type":"user","verified_identity":{},"full_name":"Alyona Dudaeva","is_ads_only_profile":false,"image_small_url":"https://i1-e.pinimg.com/30x30_RS/7d/cc/80/7dcc801c68d277fb598541c585a6740f.jpg","explicitly_followed_by_me":false,"is_verified_merchant":false},"image_signature":"a4fe657820146eb46e9c96a51cffb832","root_pin_id":"314759461476720082","aggregated_pin_data":{"node_id":"QWdncmVnYXRlZFBpbkRhdGE6NTQ0MzM0ODA3NDgzMzQ0MTkzMg==","has_xy_tags":false},"description":"Що ви знаєте про творчу кризу?\n\nЯ — ой, як багато. У мене просто неймовірний досвід спілкування зі своїм внутрішнім критиком. І, повірте, так глибоко зариваю себе тільки я. Ніхто інший на таке не здатен.\n\nПробувала боротися, аналізувала, питала себе «чому».\nА потім махнула рукою й така: ну, shit happens. Буває.\n\nТому офіційно повідомляю: я йду в цей чудовий стан під назвою «ганьба та самоаналіз».\nБуду там рефлексувати і, можливо, навіть знайду вихід.\n\nА поки — я на паузі. До 1 серпня.\nЗі мною...","board":{"node_id":"Qm9hcmQ6MzE0NzU5NTMwMTQ2Njg3MzYy","image_cover_url":"https://i.pinimg.com/200x150/15/49/68/154968ba9c65392c7bf3be2e5f840f8e.jpg","followed_by_me":false,"cover_images":{"222x":{"url":"https://i.pinimg.com/222x/15/49/68/154968ba9c65392c7bf3be2e5f840f8e.jpg","width":222}},"collaborated_by_me":false,"id":"314759530146687362","image_thumbnail_u