654766783243824","is_primary_website_verified":false,"type":"user","verified_identity":{},"full_name":"Shopee Indonesia","is_ads_only_profile":false,"image_small_url":"https://i1-e.pinimg.com/30x30_RS/c9/ad/85/c9ad85500336a4c80c459edaf1727a30.jpg","explicitly_followed_by_me":false,"is_verified_merchant":false},"image_signature":"0d50fa2c7a43dea586a649f7175c1437","root_pin_id":"4606338085095594624","aggregated_pin_data":{"node_id":"QWdncmVnYXRlZFBpbkRhdGE6Mjk4OTYyMDc3NTQ1MzY3ODMzNg==","has_xy_tags":false},"description":"Risolanami\nAneka risoles dari Holanami Kitchen\n\nRisolanami terbuat dari kulit tipis nan lembut dan dibalut tepung roti yang crunchy. Tersedia dalam berbagai varian rasa yang menggugah selera!\n- risol mayonaise beef cheese\n- risol creamy chicken ragout\n- risol lasagna (risagna)\n- risol coklat (rischoco)\n- risol kani mentai\n\nRisolanami cemilan praktis yang bisa dikonsumsi dimana saja dan kapan saja.\nTANPA BAHAN PENGAWET.\nDikirim dalam keadaan beku (frozen)\n\nMenerima pesanan untuk acara.\n\nNotes: pengiriman hanya menggunakan layanan SAMEDAY atau INSTAN untuk menjamin kesegaran dan keamanan produk.\nSAMEDAY CLOSE JAM 15.00\nINSTAN CLOSE JAM 18.00","grid_attribution":{"node_id":"VXNlcjo5MTA1NzE3NTU4MTc2NDU3MDE=","username":"ShopeePteLtd","id":"910571755817645701","is_primary_website_verified":true,"type":"user","verified_identity":{},"full_name":"Shopee","is_ads_only_profile":false,"explicitly_followed_by_me":false,"is_verified_merchant":false},"board":{"node_id":"Qm9hcmQ6MTAwNDY1NDY5ODA2NTEyNTAzNg==","image_cover_url":"https://i.pinimg.com/200x150/c9/af/72/c9af724f98dc8ad0489f3a8ea36f452b.jpg","followed_by_me":false,"cover_images":{"222x":{"url":"https://i.pinimg.com/222x/c9/af/72/c9af724f98dc8ad0489f3a8ea36f452b.jpg","width":222}},"collaborated_by_me":false,"id":"1004654698065125036","image_thumbnail_url":"https://i.pinimg.com/upload/1004654698065125036_board_thumbnail_2026-05-07-01-57-07_1010_60.jpg","type":"board","image_cover_hd_url":"h